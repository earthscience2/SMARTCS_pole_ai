# Normalize text files to LF in the repository.
* text=auto

# Source and scripts
*.py text eol=lf
*.pyw text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Config and docs
*.ini text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.conf text eol=lf
*.cfg text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf
*.log text eol=lf
*.csv text eol=lf
*.tsv text eol=lf

# Git metadata files
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.rar binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.keras binary
*.h5 binary
*.pkl binary
*.model binary
*.npy binary
*.npz binary
*.xlsx binary
*.xls binary
*.doc binary
*.docx binary
